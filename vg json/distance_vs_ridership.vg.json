{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Ridership vs Travel Distance",
    "subtitle": [
      "Ridership tends to be higher for shorter distances.",
      "This suggests commuters prefer short convenient trips,",
      "especially in urban areas with closely connected stations.",
      "As distance increases, ridership generally declines,",
      "possibly due to longer travel times or other options."
    ],
    "subtitleFontSize": 12,
    "subtitleColor": "#555",
    "subtitleLineHeight": 16,
    "font": "Georgia, Times New Roman, serif",
    "subtitleFont": "Arial, Helvetica, sans-serif",
    "align": "center",
    "anchor": "middle"
  },
  "width": 750,
  "height": 450,

  "data": {
    "url": "../data/distance_decay.csv"
  },

  "mark": {
    "type": "circle",
    "opacity": 0.45,
    "size": 80
  },

  "encoding": {
    "x": {
      "field": "distance_km",
      "type": "quantitative",
      "title": "Station-to-Station Distance (km)"
    },
    "y": {
      "field": "ridership",
      "type": "quantitative",
      "title": "Ridership",
      "axis": {
        "format": "~s"
      }
    },
    "tooltip": [
      {"field": "origin", "type": "nominal", "title": "Origin"},
      {"field": "destination", "type": "nominal", "title": "Destination"},
      {"field": "distance_km", "type": "quantitative", "title": "Distance (km)", "format": ".2f"},
      {"field": "ridership", "type": "quantitative", "title": "Ridership", "format": ","}
    ]
  }
}
