{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Klang Valley Rail Ridership Flow Map",
  "width": 600,
  "height": 600,

  "projection": {
    "type": "mercator"
  },

  "layer": [
    {
      "data": {
        "url": "../geoBoundaries-MYS-ADM2.topojson",
        "format": {
          "type": "topojson",
          "feature": "rapidrail"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#fafafa",
        "stroke": "#555",
        "strokeWidth": 1
      },
      "encoding": {
        "tooltip": [
          {
            "field": "properties.shapeName",
            "type": "nominal",
            "title": "District"
          }
        ]
      }
    },

    {
      "data": {
        "url": "../data/cleaned_flow_data.csv",
        "format": {
          "type": "csv",
          "parse": {
            "ridership": "number",
            "start_lon": "number",
            "start_lat": "number",
            "end_lon": "number",
            "end_lat": "number"
          }
        }
      },
      "mark": {
        "type": "rule",
        "opacity": 0.28,
        "strokeCap": "round"
      },
      "encoding": {
        "longitude": {
          "field": "start_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "start_lat",
          "type": "quantitative"
        },
        "longitude2": {
          "field": "end_lon",
          "type": "quantitative"
        },
        "latitude2": {
          "field": "end_lat",
          "type": "quantitative"
        },
        "size": {
          "field": "ridership",
          "type": "quantitative",
          "scale": {
            "domain": [250, 1700],
            "range": [0.5, 5]
          }
        },
        "tooltip": [
          {
            "field": "origin",
            "type": "nominal",
            "title": "From"
          },
          {
            "field": "destination",
            "type": "nominal",
            "title": "To"
          },
          {
            "field": "ridership",
            "type": "quantitative",
            "title": "Daily Flow"
          }
        ]
      }
    },

    {
      "data": {
        "url": "../data/stops.csv",
        "format": {
          "type": "csv",
          "parse": {
            "stop_lon": "number",
            "stop_lat": "number"
          }
        }
      },
      "mark": {
        "type": "circle",
        "color": "black",
        "stroke": "white",
        "strokeWidth": 0.8,
        "size": 18
      },
      "encoding": {
        "longitude": {
          "field": "stop_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "stop_lat",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "stop_name",
            "type": "nominal",
            "title": "Station"
          },
          {
            "field": "category",
            "type": "nominal",
            "title": "Type"
          }
        ]
      }
    }
  ]
}
