{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Klang Valley Rail Ridership Flow Map",
  "width": 600,
  "height": 600,

  "projection": {
    "type": "mercator"
  },

  "params": [
    {
      "name": "flow_count",
      "value": 40,
      "bind": {
        "input": "range",
        "min": 5,
        "max": 182,
        "step": 5,
        "name": "Number of flows shown: "
      }
    },
    {
      "name": "show_station_names",
      "value": true,
      "bind": {
        "input": "checkbox",
        "name": "Show station names"
      }
    }
  ],

  "layer": [
    {
      "data": {
        "url": "geoBoundaries-MYS-ADM2.topojson",
        "format": {
          "type": "topojson",
          "feature": "rapidrail"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#fafafa",
        "stroke": "#555",
        "strokeWidth": 1
      },
      "encoding": {
        "tooltip": [
          {
            "field": "properties.shapeName",
            "type": "nominal",
            "title": "District"
          }
        ]
      }
    },

    {
      "data": {
        "url": "data/cleaned_flow_data.csv",
        "format": {
          "type": "csv",
          "parse": {
            "ridership": "number",
            "start_lon": "number",
            "start_lat": "number",
            "end_lon": "number",
            "end_lat": "number"
          }
        }
      },
      "transform": [
        {
          "window": [
            {
              "op": "rank",
              "as": "flow_rank"
            }
          ],
          "sort": [
            {
              "field": "ridership",
              "order": "descending"
            }
          ]
        },
        {
          "filter": "datum.flow_rank <= flow_count"
        }
      ],
      "mark": {
        "type": "rule",
        "opacity": 0.4,
        "strokeCap": "round"
      },
      "encoding": {
        "longitude": {
          "field": "start_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "start_lat",
          "type": "quantitative"
        },
        "longitude2": {
          "field": "end_lon",
          "type": "quantitative"
        },
        "latitude2": {
          "field": "end_lat",
          "type": "quantitative"
        },
        "size": {
          "field": "ridership",
          "type": "quantitative",
          "scale": {
            "domain": [250, 1700],
            "range": [0.5, 8]
          }
        },
        "tooltip": [
          {
            "field": "origin",
            "type": "nominal",
            "title": "From"
          },
          {
            "field": "destination",
            "type": "nominal",
            "title": "To"
          },
          {
            "field": "ridership",
            "type": "quantitative",
            "title": "Daily Flow"
          }
        ]
      }
    },

    {
      "data": {
        "url": "data/stops.csv",
        "format": {
          "type": "csv",
          "parse": {
            "stop_lon": "number",
            "stop_lat": "number"
          }
        }
      },
      "mark": {
        "type": "circle",
        "color": "black",
        "stroke": "white",
        "strokeWidth": 0.8,
        "size": 18
      },
      "encoding": {
        "longitude": {
          "field": "stop_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "stop_lat",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "stop_name",
            "type": "nominal",
            "title": "Station"
          },
          {
            "field": "category",
            "type": "nominal",
            "title": "Type"
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          {"station": "KL Sentral", "lat": 3.13442, "lon": 101.68625},
          {"station": "Pasar Seni", "lat": 3.142439, "lon": 101.69531},
          {"station": "KLCC", "lat": 3.158935, "lon": 101.713287},
          {"station": "Bank Rakyat Bangsar", "lat": 3.127588, "lon": 101.679062},
          {"station": "Abdullah Hukum", "lat": 3.118735, "lon": 101.672897},
          {"station": "Universiti", "lat": 3.114616, "lon": 101.661639},
          {"station": "Tun Razak Exchange", "lat": 3.142403, "lon": 101.720156},
          {"station": "Cochrane", "lat": 3.132829, "lon": 101.722962},
          {"station": "Maluri", "lat": 3.123623, "lon": 101.727809},
          {"station": "Bukit Bintang", "lat": 3.146503, "lon": 101.710947},
          {"station": "Kota Damansara", "lat": 3.150134, "lon": 101.57869},
          {"station": "Subang Jaya", "lat": 3.08466, "lon": 101.588127}
        ]
      },
      "transform": [
        {
          "filter": "show_station_names"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 3,
        "dy": -3,
        "fontSize": 5,
        "color": "#222",
        "stroke": "black",
        "strokeWidth": 0.3
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "station",
          "type": "nominal"
        }
      }
    }
  ]
}
