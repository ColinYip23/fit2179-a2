{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Klang Valley Rail Ridership Flow Map",
  "width": 600,
  "height": 600,

  "projection": {
    "type": "mercator"
  },

  "layer": [
    {
      "data": {
        "url": "../geoBoundaries-MYS-ADM2.topojson",
        "format": {
          "type": "topojson",
          "feature": "rapidrail"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#fafafa",
        "stroke": "#555",
        "strokeWidth": 1
      },
      "encoding": {
        "tooltip": [
          {
            "field": "properties.shapeName",
            "type": "nominal",
            "title": "District"
          }
        ]
      }
    },

    {
      "data": {
        "url": "../geoBoundaries-MYS-ADM2.topojson",
        "format": {
          "type": "topojson",
          "feature": "rapidrail"
        }
      },

      "transform": [
        {
          "calculate": "datum.properties.shapeName",
          "as": "district"
        }
      ],

      "mark": {
        "type": "text",
        "fontSize": 10,
        "color": "#666"
      },

      "encoding": {
        "longitude": {
          "field": "properties.center_lon",
          "type": "quantitative"
        },

        "latitude": {
          "field": "properties.center_lat",
          "type": "quantitative"
        },

        "text": {
          "field": "district"
        }
      }
    },

    {
      "data": {
        "url": "../data/cleaned_flow_data.csv"
      },
      "transform": [
        {
          "filter": "datum.ridership > 800"
        }
      ],
      "mark": {
        "type": "rule",
        "opacity": 0.18,
        "strokeCap": "round"
      },
      "encoding": {
        "longitude": {
          "field": "start_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "start_lat",
          "type": "quantitative"
        },
        "longitude2": {
          "field": "end_lon",
          "type": "quantitative"
        },
        "latitude2": {
          "field": "end_lat",
          "type": "quantitative"
        },
        "size": {
          "field": "ridership",
          "type": "quantitative",
          "scale": {
            "range": [1, 5]
          }
        },
        "tooltip": [
          {
            "field": "origin",
            "type": "nominal",
            "title": "From"
          },
          {
            "field": "destination",
            "type": "nominal",
            "title": "To"
          },
          {
            "field": "ridership",
            "type": "quantitative",
            "title": "Daily Flow"
          }
        ]
      }
    },

    {
      "data": {
        "url": "../data/cleaned_flow_data.csv"
      },
      "mark": {
        "type": "circle",
        "color": "black",
        "size": 10
      },
      "encoding": {
        "longitude": {
          "field": "start_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "start_lat",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "origin",
            "type": "nominal",
            "title": "Station"
          }
        ]
      }
    }
  ]
}
