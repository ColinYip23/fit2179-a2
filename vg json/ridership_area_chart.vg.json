{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Daily Ridership by Public Transport Mode",
    "subtitle": [
      "The LRT, BRT, and MRT show similar daily patterns.",
      "Ridership is much higher on weekdays than weekends.",
      "Weekend ridership declines due to reduced commuting,",
      "as fewer people travel for work or school."
    ],
    "subtitleFontSize": 12,
    "subtitleColor": "#555",
    "subtitleLineHeight": 16,
    "font": "Georgia, Times New Roman, serif",
    "subtitleFont": "Arial, Helvetica, sans-serif",
    "align": "left",
    "anchor": "start",
    "offset": 20
  },

  "width": 800,
  "height": 400,

  "data": {
    "url": "../data/daily_mode_ridership.csv"
  },

  "layer": [

    {
      "transform": [{ "filter": "datum.mode == 'LRT'" }],

      "mark": {
        "type": "area",
        "opacity": 0.55
      },

      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },

        "y": {
          "field": "ridership",
          "type": "quantitative",
          "stack": null
        },

        "color": {
          "datum": "LRT"
        },

        "tooltip": [
          { "field": "date", "type": "temporal", "title": "Date" },
          { "field": "mode", "type": "nominal", "title": "Mode" },
          {
            "field": "ridership",
            "type": "quantitative",
            "title": "Ridership",
            "format": ","
          }
        ]
      }
    },

    {
      "transform": [{ "filter": "datum.mode == 'MRT'" }],

      "mark": {
        "type": "area",
        "opacity": 0.55
      },

      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal"
        },

        "y": {
          "field": "ridership",
          "type": "quantitative",
          "stack": null
        },

        "color": {
          "datum": "MRT"
        },

        "tooltip": [
          { "field": "date", "type": "temporal", "title": "Date" },
          { "field": "mode", "type": "nominal", "title": "Mode" },
          {
            "field": "ridership",
            "type": "quantitative",
            "title": "Ridership",
            "format": ","
          }
        ]
      }
    },

    {
      "transform": [{ "filter": "datum.mode == 'BRT'" }],

      "mark": {
        "type": "area",
        "opacity": 0.55
      },

      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": "Date"
        },

        "y": {
          "field": "ridership",
          "type": "quantitative",
          "title": "Ridership",
          "stack": null,
          "axis": {
            "format": "~s"
          }
        },

        "color": {
          "datum": "BRT"
        },

        "tooltip": [
          { "field": "date", "type": "temporal", "title": "Date" },
          { "field": "mode", "type": "nominal", "title": "Mode" },
          {
            "field": "ridership",
            "type": "quantitative",
            "title": "Ridership",
            "format": ","
          }
        ]
      }
    }
  ]
}
