{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "7-Day Ridership Volatility",
    "subtitle": [
      "The graph shows fluctuations in 7-day volatility.",
      "Sharp spikes occur in late February, early March, and early April.",
      "These peaks show greater variation in daily ridership,",
      "while stable sections suggest consistent commuting."
    ],
    "subtitleFontSize": 12,
    "subtitleColor": "#555",
    "subtitleLineHeight": 16,
    "font": "Georgia, Times New Roman, serif",
    "subtitleFont": "Arial, Helvetica, sans-serif",
    "align": "left",
    "anchor": "start",
    "offset": 20
  },
  "width": 800,
  "height": 400,

  "data": {
    "url": "../data/ridership_volatility.csv"
  },

  "mark": {
    "type": "line",
    "point": false,
    "strokeWidth": 3
  },

  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Date"
    },
    "y": {
      "field": "rolling_7day_std",
      "type": "quantitative",
      "title": "7-Day Rolling Standard Deviation",
      "axis": {
        "format": "~s"
      }
    },
    "tooltip": [
      {"field": "date", "type": "temporal", "title": "Date"},
      {
        "field": "rolling_7day_std",
        "type": "quantitative",
        "title": "Volatility",
        "format": ",.0f"
      }
    ]
  }
}
