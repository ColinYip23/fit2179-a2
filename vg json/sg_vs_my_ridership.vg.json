{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Singapore vs Malaysia Public Transport Ridership (2019-2024)",
    "subtitle": [
      "Malaysia has a higher proportion of riders using the LRT,",
      "while Singapore has a larger proportion of riders relying on the MRT.",
      "Both countries experienced a significant decline in ridership",
      "during 2020 and 2021 due to the COVID-19 pandemic,",
      "before gradually recovering from 2021 onwards."
    ],
    "subtitleFontSize": 12,
    "subtitleColor": "#555",
    "subtitleLineHeight": 16,
    "font": "Georgia, Times New Roman, serif",
    "subtitleFont": "Arial, Helvetica, sans-serif",
    "align": "left",
    "anchor": "start",
    "offset": 20
  },

  "data": {
    "url": "../data/cleaned_mrt_lrt_2019_2024.csv"
  },

  "facet": {
    "column": {
      "field": "source",
      "type": "nominal",
      "title": null,
      "header": {
        "labelExpr": "datum.label == 'dataset1' ? 'Singapore' : 'Malaysia'"
      }
    }
  },

  "spec": {
    "width": 300,
    "height": 400,

    "mark": "bar",

    "encoding": {
      "x": {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },

      "xOffset": {
        "field": "mode"
      },

      "y": {
        "field": "ridership",
        "type": "quantitative",
        "title": "Ridership",
        "axis": {
          "format": "~s"
        }
      },

      "color": {
        "field": "mode",
        "type": "nominal"
      },

      "tooltip": [
        { "field": "source" },
        { "field": "mode" },
        { "field": "year" },
        {
          "field": "ridership",
          "format": ","
        }
      ]
    }
  },

  "resolve": {
    "scale": {
      "y": "independent"
    }
  }
}
