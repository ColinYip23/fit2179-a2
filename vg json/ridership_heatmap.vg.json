{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Monthly Ridership Heatmap by Ride Type 2025",
    "subtitle": [
      "The heatmap shows peak ridership around July and August.",
      "Ridership is noticeably higher than the rest of the year,",
      "indicating increased travel demand during mid-year.",
      "This may be influenced by school holidays, tourism,",
      "public events, and more travel during this period."
    ],
    "subtitleFontSize": 12,
    "subtitleColor": "#555",
    "subtitleLineHeight": 16,
    "font": "Georgia, Times New Roman, serif",
    "subtitleFont": "Arial, Helvetica, sans-serif",
    "align": "left",
    "anchor": "start",
    "offset": 20
  },
  "width": 700,
  "height": 350,
  "data": {"url": "data/monthly_ridership_long.csv"},
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "Month",
      "type": "ordinal",
      "title": "Month",
      "sort": [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
      ],
      "axis": {"labelAngle": -45}
    },
    "y": {
      "field": "ride_type",
      "type": "nominal",
      "title": "Ride Type"
    },
    "color": {
      "field": "ridership",
      "type": "quantitative",
      "title": "Ridership",
      "scale": {"scheme": "blues"},
      "legend": {"format": "~s"}
    },
    "tooltip": [
      {"field": "Month", "title": "Month"},
      {"field": "ride_type", "title": "Ride Type"},
      {"field": "ridership", "title": "Ridership", "format": ","}
    ]
  }
}
